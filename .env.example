# ============================================================
# news-analytics 环境变量配置示例
# 复制为 .env 并按实际情况修改
# ============================================================

# 应用环境：production | development
APP_ENV=production

# ---- 数据库连接 -----------------------------------------------
# asyncpg 格式（FastAPI 使用）
DATABASE_URL=postgresql+asyncpg://newsletter:myapp123@localhost:5432/newsletter

# Docker Compose 分项配置（与 docker-compose.yaml 保持一致）
DB_HOST=postgres
DB_PORT=5432
DB_USER=newsletter
DB_PASSWORD=myapp123
DB_NAME=newsletter
DB_ASYNC_DRIVER=postgresql+asyncpg

# ---- 安全 ----------------------------------------------------
# 生产环境必须修改为随机强密钥，例如：
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me

# ---- 跨域 ----------------------------------------------------
# 前端域名白名单，多个用分号分隔
# 示例：CORS_ORIGINS=https://app.example.com;https://admin.example.com
CORS_ORIGINS=

# ---- 分析参数 ------------------------------------------------
# TF-IDF 最大词特征数
TFIDF_MAX_FEATURES=2000

# ---- 静态文件 ------------------------------------------------
STATIC_DIR=static
WORDCLOUD_DIR=static/wordclouds
